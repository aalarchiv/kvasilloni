; kvasilloni.ini - configuration for the canlib32.dll cannelloni shim.
;
; Copy this file to "kvasilloni.ini" and place it next to canlib32.dll (or next
; to your application's .exe). Values here are overridden by KVASILLONI_* environment
; variables if those are set, so scripted/CI runs can still override the file.
;
; The [cannelloni] section header is optional.

[cannelloni]

; IP address of the Linux host running cannelloni. IPv4 or IPv6 (e.g. ::1).
host = 192.168.1.50

; Remote port the shim sends to (cannelloni's listen port, its -l).
port = 20000

; Local port the shim binds (UDP) or listens on (TCP server).
; For UDP this is cannelloni's -r remote port.
; UDP only: each app running simultaneously needs a unique localport value.
; TCP client mode ignores this setting (the OS picks an ephemeral port).
localport = 20000

; Transport: udp (default, simplest) or tcp (reliable, ordered).
proto = udp

; TCP only: client (shim dials cannelloni -C s) or server (shim accepts
; cannelloni -C c). Ignored for udp.
tcprole = client

; Peer restriction (like cannelloni's -R / -p). With peercheck on (default) the
; shim accepts inbound traffic only from `host`. Set off to accept any source.
; In TCP-server mode, set `host` to the IP cannelloni connects FROM.
; peercheck = on
; allow = 192.168.1.50, 192.168.1.51   ; extra peer IPs (replaces the host default)

; UDP only: if localport is busy, bind an ephemeral port instead of failing the
; open. CAUTION: a stock cannelloni replies only to its fixed -r port, so an
; ephemeral bind is TX-only (no RX). Leave off unless you accept that.
; udpportfallback = off

; Optional debug log. Leave empty/omit to disable.
; log = C:\temp\kvasilloni.log
